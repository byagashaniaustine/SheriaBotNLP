# Copy to .env for local dev, or paste each key into Railway's Variables tab.

# ---- Meta WhatsApp Cloud API ------------------------------------------
# Any string you invent; must match what you type into Meta's webhook setup.
WHATSAPP_VERIFY_TOKEN=change_me_random_string

# Permanent System User access token from the Meta App dashboard.
WHATSAPP_ACCESS_TOKEN=EAAG...

# The WABA phone-number ID (a numeric string, NOT the phone number itself).
WHATSAPP_PHONE_NUMBER_ID=1234567890

# Optional: pin the Graph API version. Defaults to v20.0.
# WHATSAPP_GRAPH_VERSION=v20.0

# ---- Admin auth ------------------------------------------------------
# Long random string. Required to hit any /pipeline/* or /graphs/generate/* endpoint.
# If unset, those endpoints return 503 — secure-by-default.
ADMIN_API_KEY=change_me_long_random_secret

# ---- Session persistence --------------------------------------------
# SQLite file path. On Railway attach a Volume mounted at /data and set:
#   SESSION_DB_PATH=/data/sessions.db
# so state survives redeploys. Without a volume, sessions live inside the
# container and are wiped on every deploy.
# SESSION_DB_PATH=/data/sessions.db
